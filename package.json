{
  "name": "neonmusicplayerexpo",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "npx expo start",
    "start:dev": "npx expo start --dev-client",
    "android": "npx expo start --android",
    "android:usb": "npx expo start --android --localhost",
    "ios": "npx expo start --ios",
    "web": "npx expo start --web",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "build:preview": "eas build --platform android --profile preview",
    "submit:android": "eas submit --platform android",
    "submit:ios": "eas submit --platform ios",
    "type-check": "tsc --noEmit",
    "lint": "npx expo lint"
  },
  "dependencies": {
    "@react-navigation/drawer": "7.9.9",
    "@react-navigation/native": "7.2.4",
    "@react-navigation/native-stack": "7.14.14",
    "expo": "~54.0.34",
    "expo-av": "16.0.8",
    "expo-dev-client": "~6.0.21",
    "expo-status-bar": "3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "2.28.0",
    "react-native-permissions": "5.4.4",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "5.6.0",
    "react-native-screens": "4.16.0",
    "react-native-track-player": "4.1.2",
    "react-native-worklets": "0.5.1"
  },
  "private": true,
  "devDependencies": {
    "@types/react": "~19.1.10",
    "babel-preset-expo": "^54.0.10",
    "typescript": "~5.9.2"
  }
}
